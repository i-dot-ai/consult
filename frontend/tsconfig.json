{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules",
    "playwright-report"
  ],
  "compilerOptions": {
    "paths": {
      "$shadlib": [
        "./src/lib"
      ],
      "$shadlib/*": [
        "./src/lib/*"
      ]
    }
  }
}